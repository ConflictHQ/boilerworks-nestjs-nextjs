# Database
DATABASE_URL=postgresql://dbadmin:dbadmin@localhost:5432/boilerworks

# Redis
REDIS_URL=redis://localhost:6379/0

# Session
SESSION_SECRET=change-this-to-a-random-32-char-string-in-production

# Auth0 (shared with Django edition — same tenant)
AUTH0_DOMAIN=conflict.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CLIENT_SCOPES="openid profile email read:users create:users update:users"
AUTH0_DATABASE_CONNECTION_ID=Username-Password-Authentication

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=boilerworks

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@boilerworks.dev

# CORS
CORS_ORIGINS=http://localhost:3000

# Feature flags
FEATURE_FORMS=true
FEATURE_WORKFLOWS=true
FEATURE_SEARCH=false
FEATURE_TEMPORAL=false

# OpenSearch (used when FEATURE_SEARCH=true; API defaults to http://localhost:9200)
# OPENSEARCH_URL=http://localhost:9200

# Sentry (frontend; disabled unless DSN is set)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# App
NODE_ENV=development
PORT=4000

# Frontend
NEXT_PUBLIC_API_ROOT=http://localhost:4000
